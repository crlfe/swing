{
  "compilerOptions": {
    "noEmit": true,

    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "strict": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,

    "types": ["vite/client", "vitest/importMeta"]
  },
  "exclude": ["**/dist", "**/node_modules"]
}
