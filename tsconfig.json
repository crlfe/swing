{
  "compilerOptions": {
    "noEmit": true,

    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "strict": true,
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,

    "types": ["vite/client"]
  },
  "exclude": ["**/dist", "**/node_modules"]
}
